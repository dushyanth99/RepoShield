# .env.example
# Copy this file to .env and configure the variables for your environment

# Paths and Datastore Configuration
# CVEFIXES_SQL_PATH=/path/to/CVEfixes_v1.0.8.sql
# DB_PATH=dataset/CVEFixes.db

# Machine Learning Parameters
MODEL_CHECKPOINT=huggingface/CodeBERTa-small-v1
SAVED_MODEL_DIR=saved_models
MAX_TRAIN_SAMPLES=5000
BATCH_SIZE=8
EPOCHS=3
LEARNING_RATE=2e-5

# FastAPI Server Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
